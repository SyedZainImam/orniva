# Create a Sanity project at https://www.sanity.io/manage
# Then fill in these values and rename this file to .env.local
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# NextAuth.js - Generate a secret: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# Google OAuth - Set up at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Sanity Write Token - For contact form submissions
# Create at https://www.sanity.io/manage > Project > API > Tokens > Add Token (Editor role)
SANITY_WRITE_TOKEN=your_sanity_write_token_here
